# App name shown in the page title, sidebar logo, and landing page.
# Override to rebrand without touching code.
VITE_APP_NAME=Directed Art

# OpenRouter API key — the LLM seam (ADR-0006) reads this only as a fallback.
# In deployed environments the key comes from Rails credentials
# (credentials.dig(:openrouter, :api_key)); set it here for local dev/CI, where
# bin/dev loads .env. The app boots without it, but planning and generation
# won't work until a key is present. One OpenRouter key reaches Claude and the
# other vendors.
# OPENROUTER_API_KEY=
